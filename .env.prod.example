# Copy to .env.prod on the server and fill secrets:
#   cp .env.prod.example .env.prod

NODE_ENV=production

# Public URL (gateway on 8080 — do not use 80/443)
PUBLIC_BASE_URL=http://5.42.114.140:8080
CORS_ORIGIN=http://5.42.114.140:8080,http://5.42.114.140,http://localhost:8080

# PostgreSQL (compose service "db")
DB_DATABASE=kavkaz
DB_USERNAME=kavkaz
DB_PASSWORD=CHANGE_ME

# JWT — generate strong random values
JWT_ACCESS_SECRET=CHANGE_ME_ACCESS
JWT_REFRESH_SECRET=CHANGE_ME_REFRESH
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# TypeORM (ok for temp deploy; prefer migrations later)
DB_SYNCHRONIZE=true
DB_LOGGING=false
DB_MIGRATIONS_RUN=false
