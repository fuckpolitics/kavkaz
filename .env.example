# Application
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:3001,http://127.0.0.1:3001
PUBLIC_BASE_URL=http://localhost:3000
UPLOAD_DIR=./uploads

# JWT
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=kavkaz

# TypeORM
# Use synchronize only in local/dev; prefer migrations in production
DB_SYNCHRONIZE=false
DB_LOGGING=true
DB_MIGRATIONS_RUN=false

# SSL (production)
# DB_SSL_REJECT_UNAUTHORIZED=true

# Email OTP (SMTP). If SMTP_HOST is empty → test mode (code 0000).
# OTP_TEST_MODE=true   # force test codes even with SMTP
# OTP_TEST_MODE=false  # force real codes (requires SMTP_HOST)
# OTP_TEST_CODE=0000
# OTP_TTL_MINUTES=10
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Сорвались <noreply@sorvalis.ru>"

# SMS OTP — RU providers (pay-as-you-go)
# Recommended budget: SMS.ru (easy) or SMSC.ru (often cheaper per SMS)
# SMS_PROVIDER=smsru|smsc
SMS_PROVIDER=smsru
SMSRU_API_ID=
# SMSC_LOGIN=
# SMSC_PASSWORD=
# SMS_FROM=
